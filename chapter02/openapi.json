{
    "components": {
    },
    "info": {
        "contact": {
            "email": "mohamed@labouardy.com",
            "name": "Mohamed Labouardy",
            "url": "https://labouardy.com"
        },
        "description": "This is a sample recipes API. You can find out more about the API at https://github.com/PacktPublishing/Building-Distributed-Applications-in-Gin.",
        "title": "Recipes API",
        "version": "1.0.0"
    },
    "openapi": "3.0.1",
    "paths": {
        "/recipes": {
            "get": {
                "description": "Returns list of recipes",
                "operationId": "listRecipes",
                "responses": {
                    "200": {
                        "content": {
                        },
                        "description": "Successful operation"
                    }
                },
                "tags": [
                    "recipes"
                ]
            },
            "post": {
                "description": "Create a new recipe",
                "operationId": "newRecipe",
                "parameters": [
                    {
                        "in": "query",
                        "name": "name",
                        "schema": {
                            "type": "string",
                            "x-go-name": "Name"
                        },
                        "x-go-name": "Name"
                    },
                    {
                        "explode": false,
                        "in": "query",
                        "name": "tags",
                        "schema": {
                            "items": {
                                "type": "string"
                            },
                            "type": "array",
                            "x-go-name": "Tags"
                        },
                        "style": "form",
                        "x-go-name": "Tags"
                    },
                    {
                        "explode": false,
                        "in": "query",
                        "name": "ingredients",
                        "schema": {
                            "items": {
                                "type": "string"
                            },
                            "type": "array",
                            "x-go-name": "Ingredients"
                        },
                        "style": "form",
                        "x-go-name": "Ingredients"
                    },
                    {
                        "explode": false,
                        "in": "query",
                        "name": "instructions",
                        "schema": {
                            "items": {
                                "type": "string"
                            },
                            "type": "array",
                            "x-go-name": "Instructions"
                        },
                        "style": "form",
                        "x-go-name": "Instructions"
                    },
                    {
                        "in": "query",
                        "name": "publishedAt",
                        "schema": {
                            "format": "date-time",
                            "type": "string",
                            "x-go-name": "PublishedAt"
                        },
                        "x-go-name": "PublishedAt"
                    }
                ],
                "responses": {
                    "200": {
                        "content": {
                        },
                        "description": "Successful operation"
                    },
                    "400": {
                        "content": {
                        },
                        "description": "Invalid input"
                    }
                },
                "tags": [
                    "recipes"
                ]
            }
        },
        "/recipes/{id}": {
            "delete": {
                "description": "Delete an existing recipe",
                "operationId": "deleteRecipe",
                "parameters": [
                    {
                        "description": "ID of the recipe",
                        "in": "path",
                        "name": "id",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "content": {
                        },
                        "description": "Successful operation"
                    },
                    "404": {
                        "content": {
                        },
                        "description": "Invalid recipe ID"
                    }
                },
                "tags": [
                    "recipes"
                ]
            },
            "get": {
                "description": "Get one recipe",
                "operationId": "oneRecipe",
                "parameters": [
                    {
                        "description": "ID of the recipe",
                        "in": "path",
                        "name": "id",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "content": {
                        },
                        "description": "Successful operation"
                    },
                    "404": {
                        "content": {
                        },
                        "description": "Invalid recipe ID"
                    }
                },
                "tags": [
                    "recipes"
                ]
            },
            "put": {
                "description": "Update an existing recipe",
                "operationId": "updateRecipe",
                "parameters": [
                    {
                        "description": "ID of the recipe",
                        "in": "path",
                        "name": "id",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "content": {
                        },
                        "description": "Successful operation"
                    },
                    "400": {
                        "content": {
                        },
                        "description": "Invalid input"
                    },
                    "404": {
                        "content": {
                        },
                        "description": "Invalid recipe ID"
                    }
                },
                "tags": [
                    "recipes"
                ]
            }
        },
        "/recipes/search": {
            "get": {
                "description": "Search recipes based on tags",
                "operationId": "findRecipe",
                "parameters": [
                    {
                        "description": "recipe tag",
                        "in": "query",
                        "name": "tag",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "content": {
                        },
                        "description": "Successful operation"
                    }
                },
                "tags": [
                    "recipes"
                ]
            }
        }
    },
    "servers": [
        {
            "url": "http://localhost:8001"
        }
    ],
    "tags": [
        {
            "name": "recipes"
        }
    ],
    "x-original-swagger-version": "2.0"
}